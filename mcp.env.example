# Variáveis do docker-compose.yml (serviço MCP). Copie para .env e preencha.
# NUNCA faça commit do .env real.

# URL pública do Firefly customizado (o MCP conversa com ela).
FIREFLY_URL=https://financas.sevenclick.dev

# Domínio do Firefly — o MCP é exposto no MESMO domínio, no path /mcp.
# Endpoint final: https://financas.sevenclick.dev/mcp
FIREFLY_DOMAIN=financas.sevenclick.dev

# Personal Access Token do Firefly.
# Gere em: Options -> Profile -> OAuth -> Personal Access Tokens.
# O MCP não sobe sem este valor.
FIREFLY_PAT=
